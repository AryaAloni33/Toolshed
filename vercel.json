{
    "buildCommand": "npm run build",
    "outputDirectory": "dist/client",
    "installCommand": "npm install",
    "framework": null,
    "functions": {
        "api/server.js": {
            "runtime": "@vercel/node@3",
            "includeFiles": "dist/server/**",
            "maxDuration": 30
        }
    },
    "headers": [
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/((?!api/).*)",
            "destination": "/api/server"
        }
    ]
}